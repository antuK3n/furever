@model FurEver.Web.Models.ViewModels.AdminAdopterEditViewModel
@{
    ViewData["Title"] = $"Edit {Model.FullName}";
}

<div class="auth-card wide">
    <h1>Edit adopter</h1>

    <form asp-area="Admin" asp-controller="Adopters" asp-action="Edit" asp-route-id="@Model.AdopterId" method="post">
        <div asp-validation-summary="ModelOnly"></div>
        <input type="hidden" asp-for="AdopterId" />

        <div class="form-grid">
            <div class="form-group span-2">
                <label class="form-label" asp-for="FullName"></label>
                <input asp-for="FullName" />
                <span asp-validation-for="FullName"></span>
            </div>

            <div class="form-group span-2">
                <label class="form-label" asp-for="Email"></label>
                <input asp-for="Email" type="email" />
                <span asp-validation-for="Email"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="ContactNo"></label>
                <input asp-for="ContactNo" type="tel" />
                <span asp-validation-for="ContactNo"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="HousingType"></label>
                <select asp-for="HousingType">
                    <option>House</option>
                    <option>Apartment</option>
                    <option>Condo</option>
                    <option>Farm</option>
                </select>
                <span asp-validation-for="HousingType"></span>
            </div>

            <div class="form-group span-2">
                <label class="form-label" asp-for="Address"></label>
                <input asp-for="Address" />
                <span asp-validation-for="Address"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="HasOtherPets"></label>
                <select asp-for="HasOtherPets">
                    <option>No</option>
                    <option>Yes</option>
                </select>
                <span asp-validation-for="HasOtherPets"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="HasChildren"></label>
                <select asp-for="HasChildren">
                    <option>No</option>
                    <option>Yes</option>
                </select>
                <span asp-validation-for="HasChildren"></span>
            </div>

            <div class="form-group span-2">
                <label class="form-label" asp-for="ExperienceLevel"></label>
                <select asp-for="ExperienceLevel">
                    <option>First-time</option>
                    <option>Experienced</option>
                </select>
                <span asp-validation-for="ExperienceLevel"></span>
            </div>
        </div>

        <div class="detail-actions">
            <button type="submit" class="btn btn-primary">Save changes</button>
            <a class="btn btn-secondary" asp-area="Admin" asp-controller="Adopters"
               asp-action="Details" asp-route-id="@Model.AdopterId">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
