@model VeterinaryVisit
@{
    ViewData["Title"] = "Edit Vet Visit";
}

<div class="auth-card wide">
    <h1>Edit vet visit</h1>

    <form asp-area="Admin" asp-controller="VetVisits" asp-action="Edit" asp-route-id="@Model.VisitId" method="post">
        <partial name="_VisitForm" />
        <div class="row mt-3">
            <button type="submit" class="btn btn-primary">Save changes</button>
            <a class="btn btn-secondary" asp-area="Admin" asp-controller="VetVisits"
               asp-action="Details" asp-route-id="@Model.VisitId">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="/Views/Shared/_ValidationScriptsPartial.cshtml" />
}
