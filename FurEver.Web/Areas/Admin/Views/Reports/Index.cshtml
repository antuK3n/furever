@model ReportsViewModel
@{
    ViewData["Title"] = "Reports";
    var monthName = new DateTime(Model.Year, Model.Month, 1).ToString("MMMM yyyy");
}

<partial name="_AdminNav" />

<h1>Reports</h1>

<form method="get" class="filter-bar mt-3">
    <label class="visually-hidden" for="month">Month</label>
    <select id="month" name="month">
        @for (var m = 1; m <= 12; m++)
        {
            <option value="@m" selected="@(Model.Month == m)">
                @(new DateTime(2000, m, 1).ToString("MMMM"))
            </option>
        }
    </select>

    <label class="visually-hidden" for="year">Year</label>
    <select id="year" name="year">
        @for (var y = DateTime.Today.Year; y >= DateTime.Today.Year - 5; y--)
        {
            <option value="@y" selected="@(Model.Year == y)">@y</option>
        }
    </select>

    <button type="submit" class="btn btn-secondary">Run report</button>
</form>

<section class="section">
    <h2>Adoption activity — @monthName</h2>
    <p class="muted text-sm">Generated by the <code>sp_monthly_adoption_stats</code> stored procedure.</p>

    @if (Model.Stats is not null)
    {
        <div class="stat-grid">
            <div class="stat-card">
                <span class="stat-value">@Model.Stats.TotalAdoptions</span>
                <span class="stat-label">Applications</span>
            </div>
            <div class="stat-card">
                <span class="stat-value">@(Model.Stats.Completed ?? 0)</span>
                <span class="stat-label">Completed</span>
            </div>
            <div class="stat-card">
                <span class="stat-value">@(Model.Stats.Pending ?? 0)</span>
                <span class="stat-label">Pending</span>
            </div>
            <div class="stat-card">
                <span class="stat-value">@(Model.Stats.Cancelled ?? 0)</span>
                <span class="stat-label">Cancelled</span>
            </div>
            <div class="stat-card">
                <span class="stat-value">@(Model.Stats.Returned ?? 0)</span>
                <span class="stat-label">Returned</span>
            </div>
            <div class="stat-card">
                <span class="stat-value">@Model.Stats.TotalRevenue.ToString("C")</span>
                <span class="stat-label">Revenue</span>
            </div>
        </div>
    }
</section>

<section class="section">
    <h2>Pets by species</h2>
    @if (Model.SpeciesBreakdown.Count > 0)
    {
        <div class="table-wrap">
            <table class="data">
                <thead>
                    <tr>
                        <th>Species</th>
                        <th>Available</th>
                        <th>Total in system</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.SpeciesBreakdown)
                    {
                        <tr>
                            <td><strong>@s.Species</strong></td>
                            <td>@s.Available</td>
                            <td>@s.Total</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="muted">No pets in the system yet.</p>
    }
</section>
